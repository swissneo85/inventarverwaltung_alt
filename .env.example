# Application
APP_NAME=Inventarverwaltung
APP_ENV=local
APP_KEY=base32:GenerateWith32CharactersHere==
APP_DEBUG=true
APP_URL=http://localhost:8080

# Frontend URL (for CORS/Sanctum)
FRONTEND_URL=http://localhost:3000

# Database
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=inventar
DB_USERNAME=inventar
DB_PASSWORD=inventar_secret
DB_ROOT_PASSWORD=inventar_root_secret

# Session
SESSION_DRIVER=database
SESSION_LIFETIME=120

# Queue
QUEUE_CONNECTION=database